# ── Tauri (application desktop) ──────────────────────────────────────────────
# Identifiant pour le flow natif Tauri (PKCE, pas de client_secret)
# Dans Google Cloud Console → Identifiants → "+ Créer" → "Application de bureau"
# L'URI de redirection est gérée automatiquement (http://127.0.0.1:PORT)
VITE_GOOGLE_CLIENT_ID=votre-client-id-desktop.apps.googleusercontent.com

# ── Docker / déploiement web ──────────────────────────────────────────────────
# Identifiant pour le flow popup via proxy (type "Application Web")
# Dans Google Cloud Console → Identifiants → "+ Créer" → "Application Web"
# URI de redirection autorisée : http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=votre-client-id-web.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-client-secret

# URL publique du frontend (pour la vérification postMessage)
FRONTEND_ORIGIN=http://localhost:8080

# Doit correspondre exactement à l'URI enregistrée dans Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
